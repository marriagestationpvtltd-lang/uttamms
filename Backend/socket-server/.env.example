# =============================================================
# Marriage Station Socket.IO Server — Environment Configuration
# =============================================================
# Copy this file to .env and fill in your actual values.
# Never commit your .env file to version control.
# =============================================================

# ── Server ───────────────────────────────────────────────────
# Port the Socket.IO server listens on
PORT=3001

# ── Database ─────────────────────────────────────────────────
# Same MySQL database as the PHP backend
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ms
DB_USER=ms_dbuser
DB_PASSWORD=your_strong_db_password_here

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins for Socket.IO connections.
# Use * to allow all (NOT recommended for production).
ALLOWED_ORIGINS=https://digitallami.com,https://adminnew.marriagestation.com.np,https://adminmrz.marriagestation.com.np,https://marriagestation.com.np,http://localhost,http://localhost:61983,http://localhost:3000
ALLOWED_ORIGINS=https://digitallami.com,https://adminnew.marriagestation.com.np,https://adminmrz.marriagestation.com.np,http://localhost

# ── File Uploads ─────────────────────────────────────────────
# Directory where chat images and voice messages are stored
UPLOAD_DIR=./uploads

# Public base URL used to build file URLs returned by the /upload endpoint.
# REQUIRED for production to guarantee correct HTTPS image URLs.
# Without this, image URLs are derived from request headers which may give
# wrong results (e.g. http://localhost:3001/...) if nginx is not configured
# to forward X-Forwarded-Proto and Host headers correctly.
# Set this to your server's public HTTPS base URL (no trailing slash).
# Example: PUBLIC_URL=https://your-domain.com
PUBLIC_URL=https://your-domain.com

# ── Redis (required for multi-instance / high-concurrency mode) ──────────────
# Redis is used by the @socket.io/redis-adapter to synchronise events and
# rooms across multiple Node.js worker processes or server instances.
# Set REDIS_ENABLED=false to disable the adapter (single-instance / dev mode).
REDIS_ENABLED=true
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# Leave blank if Redis has no password
REDIS_PASSWORD=

# ── Call Signaling ────────────────────────────────────────────
# Set CALLS_ENABLED=false to disable all call-related socket events
# (call_invite, call_accept, call_reject, etc.) while keeping chat working.
# Useful for stabilisation / maintenance periods.
CALLS_ENABLED=true

# ── Admin Chat History API ────────────────────────────────────
# The GET /api/admin/chat-history endpoint is authenticated by validating the
# admin bearer token against the admin_tokens table (same token the PHP login
# endpoint issues).  No extra secret is required — just ensure the admin_tokens
# table is present and correctly populated by the PHP backend.
