# =============================================================
# Marriage Station Socket.IO Server — Environment Configuration
# =============================================================
# Copy this file to .env and fill in your actual values.
# Never commit your .env file to version control.
# =============================================================

# ── Server ───────────────────────────────────────────────────
# Port the Socket.IO server listens on
PORT=3001

# ── Database ─────────────────────────────────────────────────
# Same MySQL database as the PHP backend
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ms
DB_USER=ms_dbuser
DB_PASSWORD=your_strong_db_password_here

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins for Socket.IO connections.
# Use * to allow all (NOT recommended for production).
ALLOWED_ORIGINS=https://digitallami.com,https://adminnew.marriagestation.com.np,https://adminmrz.marriagestation.com.np,http://localhost:3000

# ── File Uploads ─────────────────────────────────────────────
# Directory where chat images and voice messages are stored
UPLOAD_DIR=./uploads

# ── Redis (required for multi-instance / high-concurrency mode) ──────────────
# Redis is used by the @socket.io/redis-adapter to synchronise events and
# rooms across multiple Node.js worker processes or server instances.
# Set REDIS_ENABLED=false to disable the adapter (single-instance / dev mode).
REDIS_ENABLED=true
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# Leave blank if Redis has no password
REDIS_PASSWORD=

# ── Agora Cloud Recording ─────────────────────────────────────
# Set these to enable call recording so admins can listen back to completed calls.
# Create RESTful API credentials at https://console.agora.io
# Leave AGORA_CUSTOMER_ID blank to disable cloud recording (endpoints return 501).
AGORA_APP_ID=your_agora_app_id_here
AGORA_CUSTOMER_ID=
AGORA_CUSTOMER_SECRET=

# Storage for recorded files (required when recording is enabled).
# AGORA_STORAGE_VENDOR: 1=Qiniu, 2=Amazon S3, 3=Alibaba OSS, 6=Microsoft Azure
AGORA_STORAGE_VENDOR=2
AGORA_STORAGE_REGION=1
AGORA_STORAGE_BUCKET=
AGORA_STORAGE_KEY=
AGORA_STORAGE_SECRET=
