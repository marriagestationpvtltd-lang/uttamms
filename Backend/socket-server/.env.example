# =============================================================
# Marriage Station Socket.IO Server — Environment Configuration
# =============================================================
# Copy this file to .env and fill in your actual values.
# Never commit your .env file to version control.
#
# All variables are OPTIONAL — the server uses the defaults shown
# below if a variable is not set in .env.
# =============================================================

# ── Server ───────────────────────────────────────────────────
# [OPTIONAL] Port the Socket.IO server listens on
PORT=3001

# ── Database ─────────────────────────────────────────────────
# MySQL database used by the socket server.
# These should match the credentials in db_connect.php (PHP backend).
# The server falls back to these values if the variable is not set,
# but it is recommended to set them explicitly in production.
DB_HOST=localhost
# [OPTIONAL] MySQL port — defaults to 3306 when not set.
DB_PORT=3306
DB_NAME=ms
DB_USER=ms
DB_PASSWORD=ms
# [OPTIONAL] MySQL connection pool size — increase for higher concurrency.
DB_POOL_LIMIT=100

# ── CORS ─────────────────────────────────────────────────────
# [OPTIONAL] Comma-separated list of allowed origins.
# Use * to allow all (NOT recommended for production).
ALLOWED_ORIGINS=https://digitallami.com,https://adminnew.marriagestation.com.np,https://adminmrz.marriagestation.com.np,http://localhost:3000

# ── File Uploads ─────────────────────────────────────────────
# [OPTIONAL] Directory where chat images and voice messages are stored.
UPLOAD_DIR=./uploads
# [OPTIONAL] Server-side image compression settings (sharp).
# Images are resized to at most IMAGE_MAX_DIMENSION × IMAGE_MAX_DIMENSION px
# and re-encoded as JPEG at IMAGE_JPEG_QUALITY (1-100).
IMAGE_MAX_DIMENSION=1200
IMAGE_JPEG_QUALITY=80

# [OPTIONAL] Public base URL used to build file URLs returned by /upload.
# When set, this value is always used instead of the auto-detected
# protocol+host from request headers.
# Recommended for production to guarantee correct HTTPS URLs.
# Example: PUBLIC_URL=https://adminnew.marriagestation.com.np
PUBLIC_URL=

# ── Redis (optional — only needed for multi-instance / high-concurrency mode) ─
# Set REDIS_ENABLED=true ONLY if you have Redis running and want to run
# multiple Node.js instances (horizontal scaling).
# Leave as false for a single-instance / standard deployment.
REDIS_ENABLED=false
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# Leave blank if Redis has no password.
REDIS_PASSWORD=

# ── Call Signaling ────────────────────────────────────────────
# [OPTIONAL] Set CALLS_ENABLED=false to disable all call-related socket events
# while keeping chat working. Useful for stabilisation / maintenance periods.
CALLS_ENABLED=true

# ── Admin Chat History API ────────────────────────────────────
# The GET /api/admin/chat-history endpoint is authenticated by validating the
# admin bearer token against the admin_tokens table (same token the PHP login
# endpoint issues).  No extra secret is required — just ensure the admin_tokens
# table is present and correctly populated by the PHP backend.
