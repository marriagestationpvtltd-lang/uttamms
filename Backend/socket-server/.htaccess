# ============================================================
# cPanel / Apache proxy rules for the Socket.IO server
# ============================================================
# Place this file in the document-root of the sub-domain or
# domain that points to this Node.js application in cPanel's
# "Setup Node.js App" feature (e.g. public_html of the sub-domain).
#
# How it works:
#   Apache (port 443, SSL) listens for incoming wss:// / https://
#   requests and forwards them to the Node.js process running
#   plain HTTP on localhost:PORT (default 3001).
#   This means Node.js never needs to handle SSL itself.
#
# Prerequisites (all enabled by default on cPanel hosts):
#   mod_rewrite, mod_proxy, mod_proxy_http, mod_proxy_wstunnel
#
# After uploading, restart the Node.js app in cPanel's
# "Setup Node.js App" panel so the new proxy takes effect.
# ============================================================

DirectoryIndex disabled
Options -Indexes

RewriteEngine On

# ── 1. WebSocket upgrade (wss://) ─────────────────────────────
# Matches only when the browser sends an HTTP Upgrade: websocket header.
# mod_proxy_wstunnel handles the protocol switch; the upstream sees a
# plain ws:// connection.
#
# ⚠️  PORT: change 3001 to match the PORT value in your .env file.
#           You must update BOTH rewrite rules whenever you change the port.
RewriteCond %{HTTP:Upgrade} websocket [NC]
RewriteCond %{HTTP:Connection} upgrade [NC]
RewriteRule ^/?(.*) "ws://127.0.0.1:3001/$1" [P,L]

# ── 2. HTTP long-polling + REST (https://) ────────────────────
# All remaining requests (Socket.IO polling handshake, /upload,
# /health, etc.) are forwarded as plain HTTP to Node.js.
# Apache's mod_proxy keeps the SSL session with the browser while
# talking plain HTTP to Node.js internally — no SSL cert needed in Node.
#
# ⚠️  PORT: change 3001 here to match the PORT in your .env file.
RewriteRule ^/?(.*) "http://127.0.0.1:3001/$1" [P,L]
