# Deny direct execution of any PHP scripts uploaded to this directory.

# Block PHP execution in uploads
<FilesMatch "\.ph(p[0-9]?|tml|ar)$">
    Require all denied
</FilesMatch>

# Ensure files are served as plain content, never executed
AddType text/plain .php .phtml .php3 .php4 .php5 .php7 .phps .phar

# Disable directory listings
Options -Indexes

# Allow cross-origin requests for static assets (images, audio, etc.)
<IfModule mod_headers.c>
    <FilesMatch "\.(jpg|jpeg|png|gif|webp|svg|ico|mp3|ogg|wav|mp4|pdf)$">
        Header set Access-Control-Allow-Origin "*"
        Header set Access-Control-Allow-Methods "GET, OPTIONS"
        Header set Access-Control-Allow-Headers "Origin, Accept, Content-Type"
    </FilesMatch>
</IfModule>
